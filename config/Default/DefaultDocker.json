{
  "Default": {
    "Docker": {
      "webrcade": {
        "Name": "webrcade",
        "Image": "webrcade/webrcade",
        "Port": "8080:80",
        "Location": "~/projects/webArcade/webrcade-master/",
        "Download": "https://codeload.github.com/webrcade/webrcade/zip/refs/heads/master",
        "TmpDir": "/tmp/docker_downloads"
      },
      "dataanalysis-tool": {
        "Name": "dataanalysis-tool",
        "Location": "~/projects/dataAnalysis/dataanalysis-tool/",
        "Download": "https://codeload.github.com/nigelgalbraith/DataAnalysisTool/zip/refs/heads/main",
        "TmpDir": "/tmp/docker_downloads",
        "ComposeFile": "~/projects/dataAnalysis/dataanalysis-tool/docker-compose.yml",
        "ComposeDir": "~/projects/dataAnalysis/dataanalysis-tool",
        "ComposeContainers": [
          "dataanalysis-postgres",
          "dataanalysis-api",
          "dataanalysis-web"
        ],
        "Tests": [
          {"label": "heathcheck", "path": "~/Documents/GitHub/DebianScripts/settings/tests/common/healthcheck.py"},
          {"label": "route-tests", "path": "~/Documents/GitHub/DebianScripts/settings/tests/dataanalysis-tool/routes/routes-tests.py"}
        ]
      },
      "language-translator": {
        "Name": "language-translator",
        "Location": "~/projects/AI/LanguageTranslator/",
        "Download": "https://codeload.github.com/nigelgalbraith/LanguageTranslator/zip/refs/heads/main",
        "TmpDir": "/tmp/docker_downloads",
        "ComposeFile": "~/projects/AI/LanguageTranslator/docker-compose.yml",
        "ComposeDir": "~/projects/AI/LanguageTranslator",
        "ComposeContainers": [
          "translate-ui",
          "piper-en",
          "piper-es",
          "piper-zh"
        ],
        "Tests": [
          {"label": "heathcheck", "path": "~/Documents/GitHub/DebianScripts/settings/tests/common/healthcheck.py"}
        ]
      },
      "text-creator": {
        "Name": "text-creator",
        "Location": "~/projects/AI/TextCreator/",
        "Download": "https://codeload.github.com/nigelgalbraith/PromptTextCreator/zip/refs/heads/main",
        "TmpDir": "/tmp/docker_downloads",
        "ComposeFile": "~/projects/AI/TextCreator/docker-compose.yml",
        "ComposeDir": "~/projects/AI/TextCreator",
        "ComposeContainers": [
          "text-generator-ui",
          "ollama",
          "piper"
        ],
        "Tests": [
          {"label": "heathcheck", "path": "~/Documents/GitHub/DebianScripts/settings/tests/common/healthcheck.py"}
        ]
      },
      "Prompt-creator": {
        "Name": "prompt-creator",
        "Location": "~/projects/AI/PromptForge/",
        "Download": "https://codeload.github.com/nigelgalbraith/PromptForge/zip/refs/heads/main",
        "TmpDir": "/tmp/docker_downloads",
        "ComposeFile": "~/projects/AI/PromptForge/docker-compose.yml",
        "ComposeDir": "~/projects/AI/PromptForge",
        "ComposeContainers": [
          "web",
          "api",
          "ollama",
          "openwebui",
          "localai",
          "piper"
        ],
        "Tests": [
          {"label": "heathcheck", "path": "~/Documents/GitHub/DebianScripts/settings/tests/common/healthcheck.py"}
        ]
      }
    }
  }
}
