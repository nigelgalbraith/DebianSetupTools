{
  "Default": {
    "DOSLoader": {
      "Monkey":
      {
        "Name": "The Secret of Monkey Island",
        "DownloadURL": "https://archive.org/download/monkey_dos/MONKEY.zip",
        "DownloadPath": "/tmp/dos_downloads",
        "ExtractTo": "/srv/dosgames/monkey",
        "CheckPath": "/srv/dosgames/monkey",
        "StripTopLevel": true,
        "DosGroups": ["dosgamers"],
        "DosUsers": ["user1","user2"],
        "ChownGroup": "dosgamers",
        "ChownUser": "user1",
        "ChownRecursive": true,
        "ChownPaths": [
          {"path": "/srv/dosgames/monkey"}
        ],
        "ChmodPaths": [
          {"path": "/srv/dosgames/monkey",
            "mode": "2775",
            "recursive": true
          }
        ],
        "LaunchCmd": "dosbox -c \"mount c /srv/dosgames/monkey\" -c \"c:\" -c \"monkey.exe\"",
        "Icon": "/srv/dosgames/icons/monkey.png",
        "IconFile":   [
          {
            "copyName": "DOS Icons",
            "src": "settings/dosgameIcons/monkey.png",
            "dest": "/srv/dosgames/icons/monkey.png"
          }
        ],
        "Category": "Game;",
        "PostInstall": [],
        "Notes": "Runs in DOSBox. Default launch assumes MONKEY.EXE is present.",
        "ProtectedFolders": [
          {
            "path": "/srv/dosgames",
            "owner": "root",
            "group": "dosgamers",
            "permissions": "3775"
          }
        ]
      }
    }
  }
}