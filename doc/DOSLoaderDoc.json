  "EDITABLE_FIELDS": [
    "<MODEL_ID>",
    "<MODEL_ID>.DOSLoader.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.Name.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.DownloadURL.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.DownloadPath.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.ExtractTo.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.CheckPath.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.StripTopLevel.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.DosGroups.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.DosUsers.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.ChownGroup.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.ChownUser.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.ChownRecursive.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.ChownPaths.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.ChmodPaths.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.LaunchCmd.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.Icon.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.IconDir.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.Category.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.PostInstall.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.Notes.<VALUES>",
    "<MODEL_ID>.DOSLoader.<VALUES>.ProtectedFolders.<VALUES>"
  ],
  "EXAMPLE": {
    "<MODEL_ID>": {
      "DOSLoader": {
        "Monkey": {
          "Name": "The Secret of Monkey Island",
          "DownloadURL": "https://archive.org/download/monkey_dos/MONKEY.zip",
          "DownloadPath": "/tmp/dos_downloads",
          "ExtractTo": "/home/nigel/dosgames/monkey",
          "CheckPath": "/home/nigel/dosgames/monkey",
          "StripTopLevel": true,
          "DosGroups": ["dosgamers"],
          "DosUsers": ["nigel", "rdp"],
          "ChownGroup": "dosgamers",
          "ChownUser": "nigel",
          "ChownRecursive": true,
          "ChownPaths": [
            {
              "path": "/home/nigel/dosgames/monkey"
            }
          ],
          "ChmodPaths": [
            {
              "path": "/home/nigel/dosgames/monkey",
              "mode": "3775",
              "recursive": true
            }
          ],
          "LaunchCmd": "dosbox -c \"mount c /home/nigel/dosgames/monkey\" -c \"c:\" -c \"monkey.exe\"",
          "Icon": "/home/nigel/dosgames/icons/monkey.png",
          "IconDir": [
            {
              "copyName": "DOS Icons",
              "src": "settings/dosgameIcons",
              "dest": "/home/nigel/dosgames/icons"
            }
          ],
          "Category": "Game;",
          "PostInstall": [],
          "Notes": "Runs in DOSBox. Default launch assumes MONKEY.EXE is present.",
          "ProtectedFolders": [
            {
              "path": "/home/nigel/dosgames/monkey",
              "owner": "root",
              "group": "dosgamers",
              "permissions": "3775"
            }
          ]
        }
      }
    }
  },
  "DESCRIPTION": {
    "<MODEL_ID>.DOSLoader.<VALUES>": "A DOS game definition.",
